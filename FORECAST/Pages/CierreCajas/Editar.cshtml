@page
@model MotoRepuestosRojas.Pages.CierreCajas.EditarModel
@{
    ViewData["Title"] = "Cierre Cajas";
    NumberFormatInfo formato = new CultureInfo("es-CR").NumberFormat;
    formato.CurrencySymbol = "";
    formato.CurrencyGroupSeparator = ",";
    formato.NumberDecimalSeparator = ".";
}
@using Microsoft.AspNetCore.Http
@using System;
@using System.Collections.Generic;
@using System.IO;
@using System.Linq;
@using System.Security.Claims;
@using System.Threading.Tasks;
@using Microsoft.AspNetCore.Mvc;
@using Microsoft.AspNetCore.Mvc.RazorPages;
@using Microsoft.Extensions.Configuration;
@using Refit;
@using Sicsoft.Checkin.Web.Models;
@inject IHttpContextAccessor httpContextAccessor
@{
    var Roles = ((ClaimsIdentity)User.Identity).Claims.Where(d => d.Type == "Roles").Select(s1 => s1.Value).FirstOrDefault().Split("|");
}
@section styles {


}
@section scripts {


    <script>
         var btn = document.getElementById('Guardar');
         $(document).ready(function () {
             Ocultar();
             Totalizado();


             btn.disabled = false;
             var Anterior = "@Model.Anterior";
             if (Anterior === "SI") {
                 Swal.fire({
                     icon: 'warning',
                     title: 'Advertencia...',
                     text: 'Esta caja tiene un cierre del dÃ­a anterior pendiente, por ello es redireccionado a esta página para que se realice'
                 });
             }
         });
        var Pais = "";
         function onChangeTotales() {
             try {
               
                     var EfectivoColones = parseFloat($("#EfectivoColonesC").val());
                     var TarjetasColones = parseFloat($("#TarjetaColonesC").val());
                     var ChequesColones = parseFloat($("#ChequesColonesC").val());
                     var OtrosColones = parseFloat($("#OtrosMediosColonesC").val());
                     var TransferenciasColones = parseFloat($("#TransferenciasColonesC").val());
                 



                 var EfectivoDolares = parseFloat($("#EfectivoDolaresC").val());
                 var TarjetasDolares = parseFloat($("#TarjetaDolaresC").val());
                 var ChequesDolares = parseFloat($("#ChequesDolaresC").val());
                 var OtrosDolares = parseFloat($("#OtrosMediosFCC").val());
                 var TransferenciasDolares = parseFloat($("#TransferenciasDolaresC").val());


                 var TotalizadoColones = EfectivoColones + TarjetasColones + ChequesColones + OtrosColones + TransferenciasColones;
                 var TotalizadoDolares = EfectivoDolares + TarjetasDolares + ChequesDolares + OtrosDolares + TransferenciasDolares;

                 $("#Colones").val(TotalizadoColones);
                 $("#Dolares").val(TotalizadoDolares);

                 Totalizado();

             } catch (e) {
                 alert(e);

             }


         }
         function Totalizado() {
             try {
               
              
                     var Colones = parseFloat($("#Colones").val());
                     var Dolares = (parseFloat($("#Dolares").val()));

                     var Totalizado = parseFloat((Colones + Dolares).toFixed(2));
                

                 $("#TotalizadoMonedas").val(Totalizado);

             
                     var TColones = parseFloat($("#TColones").val());
                     var FaltanteC = (TColones - Colones).toFixed(2);
                 

                 var TDolares = parseFloat($("#TDolares").val());


                 var FaltanteD = (TDolares - parseFloat($("#Dolares").val())).toFixed(2);

                     $("#FColones").val(FaltanteC);
                 

                 $("#FDolares").val(FaltanteD);


             } catch (e) {
                 alert(e);
             }
         }


         function Imprimir() {
             try {
                 var html = $("#html2").html();
                 html2pdf().from(html).set({
                     margin: 1,
                     filename: 'Cierre.pdf',
                     image: { type: 'jpeg', quality: 1 },
                     html2canvas: { scale: 2, logging: true },
                     jsPDF: { unit: 'in', format: 'A2', orientation: 'portrait' }
                 }).save();

             } catch (e) {
                 console.error(e);
             }
         }

         function Generar() {
             try {
                 btn.disabled = true;
                 $("#divProcesando").modal("show");
                 Rellenar();
                 $("#divProcesando").modal("hide");
                 Swal.fire({
                     title: 'Se descargará¡ un reporte en PDF',
                     icon: 'warning',
                     confirmButtonColor: '#3085d6',
                     confirmButtonText: 'Ok'
                 }).then((result) => {
                     if (result.isConfirmed) {
                         $("#formTipos").submit();

                     }
                 });
             } catch (e) {
                 console.error(e);
             }
         }

         function Rellenar() {
             try {
              

                
                 var EfectivoColones = parseFloat($("#EfectivoColonesC").val()) || 0;
                 var TarjetaColones = parseFloat($("#TarjetaColonesC").val()) || 0;
                 var ChequesColones = parseFloat($("#ChequesColonesC").val()) || 0;
                 var OtrosMediosColones = parseFloat($("#OtrosMediosColonesC").val()) || 0;
                 var TransferenciasColones = parseFloat($("#TransferenciasColonesC").val()) || 0;
                 var Colones = parseFloat($("#Colones").val()) || 0;
                 var FaltanteCol = parseFloat($("#FColones").val()) || 0;
                 

                 var EfectivoDolares = parseFloat($("#EfectivoDolaresC").val()) || 0;
                 var TarjetaDolares = parseFloat($("#TarjetaDolaresC").val()) || 0;
                 var ChequesDolares = parseFloat($("#ChequesDolaresC").val()) || 0;
                 var OtrosMediosFC = parseFloat($("#OtrosMediosFCC").val()) || 0;
                 var TransferenciasDolares = parseFloat($("#TransferenciasDolaresC").val()) || 0;
                 var Dolares = parseFloat($("#Dolares").val()) || 0;
          
                 var Totalizado = (Colones + (Dolares)).toFixed(2);
               
                 var FaltanteDol = parseFloat($("#FDolares").val()) || 0;

                 if (Pais == "C" || Pais == "" ) {
                 $("#EfecColC").text("₡" + formatoDecimal(EfectivoColones.toFixed(2)));
                 $("#TarjColC").text("₡" + formatoDecimal(TarjetaColones.toFixed(2)));
                 $("#CheColC").text("₡" + formatoDecimal(ChequesColones.toFixed(2)));
                 $("#OtroColC").text("₡" + formatoDecimal(OtrosMediosColones.toFixed(2)));
                 $("#TranColC").text("₡" + formatoDecimal(TransferenciasColones.toFixed(2)));
                 $("#TotalRegisCol").text("₡" + formatoDecimal(Colones.toFixed(2)));
                 $("#FColonesC").text("₡" + formatoDecimal(FaltanteCol.toFixed(2)));
                 }

                 $("#EfecDoC").text("$" + formatoDecimal(EfectivoDolares.toFixed(2)));
                 $("#TarjDolC").text("$" + formatoDecimal(TarjetaDolares.toFixed(2)));
                 $("#CheqDolC").text("$" + formatoDecimal(ChequesDolares.toFixed(2)));
                 $("#OtroDolC").text("$" + formatoDecimal(OtrosMediosFC.toFixed(2)));
                 $("#TranDolC").text("$" + formatoDecimal(TransferenciasDolares.toFixed(2)));
                 $("#TotalRegisDol").text("$" + formatoDecimal(Dolares.toFixed(2)));
                $("#Total").text("₡" + formatoDecimal(Totalizado));
                 $("#FDolaresC").text("$" + formatoDecimal(FaltanteDol.toFixed(2)));

                 Imprimir();
             } catch (e) {
                 console.error(e);
                 Swal.fire({
                     icon: 'error',
                     title: 'Oops...',
                     text: 'Error ' + e
                 });
             }
         }

       


    </script>


}


@using Newtonsoft.Json;
@using System.Globalization
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Cierre de Cajas</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    Generar Cierre
                </li>
            </ol>
        </nav>
    </div>
</div>

<section class="content ">
    <div class="row">
        <div class="col-12">
         

            @{
                var cond = Model.Condicion;
            }



            <div class="card mb-3">
                <div class="card-header">
                    <div class="row">
                        <div class="col-8">
                            <h4 class="mb-0">Generar Cierre de Caja</h4>


                        </div>
                        <div class="col-4">
                            <a asp-page="./Index"
                               class="btn btn-outline-light btn-sm float-end me-3"
                               style="text-decoration: underline;">
                                <i class="lni lni-reply"></i> Regresar
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <!-- title row -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="page-header mt-0">
                                <h2 class="d-inline"><span class="font-size-24">Cierre Caja</span></h2>
                                <div class="text-left">
                                    <h5>Fecha <span class="font-size-18">@Model.Cierres.FechaCaja.ToString("dd MMM yyy")</span></h5>


                                </div>

                            </div>

                        </div>
                        <div class="col-md-3">
