                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Tarjetas Dólares</label>
                                    <input id="TarjetaDolaresC" asp-for="Cierres.TarjetasFCC" number onchange="javascript: onChangeTotales();" class="form-control">


                                </div>
                            </div>
                            <!-- /.col -->
                        </div>


                        <!-- title row -->
                        <div class="row">
                         

                                <div class="col-md-3">

                                    <div class="form-group">
                                        <label>Cheques Colones</label>
