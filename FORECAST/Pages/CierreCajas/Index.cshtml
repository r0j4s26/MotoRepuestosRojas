@page
@using System.Globalization
@model MotoRepuestosRojas.Pages.CierreCajas.IndexModel
@{
    ViewData["Title"] = "CierreCajas";
    NumberFormatInfo formato = new CultureInfo("es-CR").NumberFormat;
    formato.CurrencySymbol = "";
    formato.CurrencyGroupSeparator = ",";
    formato.NumberDecimalSeparator = ".";
}
@section styles {


}

@section scripts {

    <script>
        try {
            $(document).ready(function () {
                jQuery(document).ready(function ($) {
                    $(document).ready(function () {
                        $('.mi-selector').select2();
                    });
                });
                $(".js-example-responsive").select2({
                    width: 'resolve',// need to override the changed default
                    height: 'resolve'
                });





            });
        } catch (e) {
            console.log(e);
            Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: 'Ha ocurrido un error al intentar imprimir ' + e

            })
        }

        var ids = 0;
        var fecha = 0;
        var idUser = 0;
        function onClickModal(idCaja, FechaCaja, idUsuario) {
            try {
                ids = idCaja;
                fecha = FechaCaja;
                idUser = idUsuario;

                Swal.fire({
                    title: 'Â¿Desea desactivar/activar el Cierre?',
                    showDenyButton: true,
                    showCancelButton: false,
                    confirmButtonText: `Aceptar`,
                    denyButtonText: `Cancelar`,
                    customClass: {
                        confirmButton: 'swalBtnColor',
                        denyButton: 'swalDeny'
                    },
                }).then((result) => {
                    /* Read more about isConfirmed, isDenied below */
                    if (result.isConfirmed) {

                        EliminarCierre();

                    }
                })
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }

        }
        function EliminarCierre() {
            try {
                $.ajax({
                    type: 'GET',
                    dataType: 'json',
                    url: '@Url.Page("Index", "EliminarCierre")',
                    data: { idCaja: ids, FechaCaja: fecha, idUsuario: idUser },
                    success: function (result) {

                        if (result == false) {
                            ids = 0;
                            fecha = 0;
                            idUser = 0;
                            Swal.fire({
                                icon: 'error',
                                title: 'Oops...',
                                text: 'Ha ocurrido un error al intentar descactivar/activar'

                            })

                        } else {
                            Swal.fire({
                                title: "Ha sido desactivado/activado con Ã©xito",

                                icon: 'success',
                                showCancelButton: false,
                                customClass: {
                                    confirmButton: 'swalBtnColor',

                                },
                                confirmButtonText: 'OK'
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    location.reload();
                                }
                            })
                        }
                    },
                    beforeSend: function () {

                    }
                })
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }



    </script>

}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Cierre de Cajas</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    Listado de Cierres de Caja
                </li>
            </ol>
        </nav>
    </div>
</div>
<!-- Main content -->
<section class="content">
    <div class="row">
        <div class="col-12">


            <div class="card">
                <div class="card-body">
                    <div class="card-title">
                        <div class="row">
                            <div class="col-sm-8"><h4 class="mb-0">Filtros</h4></div>


                        </div>
                    </div>
                    <hr />
                </div>
                <div class="card-body pt-0">
                    <form method="get">
                        <div class="row">
                            <div class="col-sm-2 pr-1">
                                <div class="form-group">
                                    <label>Fecha Inicial</label>
                                    <input class="form-control " id="FecInicial" type="date" asp-for="filtro.FechaInicial">
                                </div>


                            </div>

                            <div class="col-sm-2 pl-1">
                                <div class="form-group">
                                    <label>Fecha Final</label>
                                    <input class="form-control" id="FecFinal" type="date" asp-for="filtro.FechaFinal">
                                </div>
                            </div>
                            <div class="col-sm-2 pr-1">
                                <div class="form-group">
                                    <label>Usuarios</label>
                                    <select class="form-control single-select select2" asp-for="filtro.Codigo1">
                                        <option value="0"> Seleccione</option>

                                        @foreach (var item in Model.Users)
                                        {
                                            <option value="@item.id"> @item.Nombre</option>
                                        }


                                    </select>
                                </div>


                            </div>

                            <div class="col-sm-2 pr-1">
                                <div class="form-group">
                                    <label>Cajas</label>
                                    <select class="form-control single-select select2" asp-for="filtro.Codigo2">
                                        <option value="0"> Seleccione</option>

                                        @foreach (var item in Model.Cajas)
                                        {
                                            <option value="@item.id"> @item.Nombre</option>
                                        }


                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-2  pl-1" style="text-align: center; padding-top: 2%;">
                                <input type="checkbox" id="md_checkbox_1" class="chk-col-red" asp-for="filtro.Activo" onclick="this.form.submit()" />
                                <label for="md_checkbox_1">Activo</label>
                            </div>


                            <div class="col-sm-2 pl-1" style="text-align: center; padding-top: 1%;">
                                <button title="Buscar" type="submit" class="btn btn-rounded btn-outline-primary"> <i class="fa fa-search"></i></button>
                            </div>




                        </div>

                    </form>
                </div>
            </div>
            <div class="card mt-3">
                <div class="card-body">
                    <div class="card-title">
                        <div class="row align-items-center">
                            <div class="col-sm-8">
                                <h4 class="mb-0">Listado de Cierres de Caja</h4>
                            </div>
                        </div>
                    </div>
                    <hr />
                    <div class="table-responsive">
                        <table id="example1" class="table table-striped table-bordered datatable">
                            <thead>
                                <tr>

                                    <th>Caja</th>
                                  

                                    <th>Fecha</th>
                                    <th>Última Actualización</th>

                                    <th>Total Vendido Colones</th>

                                    <th>Total Vendido Dolares</th>
                                    <th>Total Vendido</th>
                                    <th>Hora de Cierre</th>
                                    <th>Activo</th>
                                    <th>Acción</th>


                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Cierre)
                                {
                                    <tr>

                                        <td>  @(Model.Cajas.Where(a => a.id == item.idCaja).FirstOrDefault() == null ? "Caja Inexistente" : Model.Cajas.Where(a => a.id == item.idCaja).FirstOrDefault().Nombre) </td>
                                       

                                        <td>
                                            @item.FechaCaja.ToString("dd/MM/yyyy")
                                        </td>

                                        <td>
                                            @item.FecUltAct.ToString("dd/MM/yyyy")
                                        </td>

                                        <td>
                                            ₡@Math.Round(@item.TotalVendidoColones, 2).ToString("C", formato)
                                        </td>




                                        <td>
                                            $@Math.Round(@item.TotalVendidoFC, 2).ToString("C", formato)
                                        </td>

                                        <td>
                                            ₡@Math.Round(item.TotalizadoMonedas, 2).ToString("C", formato)
                                        </td>


                                        <td>
                                            @item.HoraCierre.ToString("hh:mm tt")
                                        </td>

                                        <td>
                                            @if (item.Activo)
                                            {
                                                <span class="badge rounded-pill text-bg-success">Activo</span>

                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill text-bg-danger">Cerrado</span>
                                            }

                                        </td>

                                        <td align="center" style="padding-top:15px;">

                                            <a asp-page="./Observar" asp-route-id="@item.idCaja" asp-route-Fecha="@item.FechaCaja.ToString("MM-dd-yyyy")" class="btn btn-rounded btn-outline-info">Observar</a>
                                            &nbsp;
                                           

                                            @if (item.Activo)
                                            {
                                                <a onclick="javascript: onClickModal('@item.idCaja', '@item.FechaCaja')"
                                                   class="btn btn-rounded btn-outline-danger">
                                                    Desactivar
                                                </a>
                                            }
                                            else
                                            {
                                                <a> onclick ="javascript: onClickModal('@item.idCaja', '@item.FechaCaja')"
                                                          class="btn btn-rounded btn-outline-success">
                                                    Activar
                                                </a>
                                            }
                                        
                                      

                                        </td>



                                    </tr>

                                }


                            </tbody>
                            <tfoot>
                                <tr>
                                    <th>Caja</th>
                               
                             
                                    <th>Fecha</th>
                                    <th>Última Actualización</th>

                                    <th>Total Vendido Colones</th>


                                    <th>Total Vendido $</th>
                                    <th>Total Vendido</th>
                                    <th>Hora de Cierre</th>
                                    <th>Activo</th>
                                    <th>Acción</th>

                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <!-- /.box-body -->
            </div>
            <!-- /.box -->
        </div>
        <!-- /.col -->
    </div>
    <!-- /.row -->
</section>
<!-- /.content -->
