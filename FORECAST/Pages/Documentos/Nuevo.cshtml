@page
@model MotoRepuestosRojas.Pages.Documentos.NuevoModel
@{
    ViewData["Title"] = "Documentos";
}

@using Microsoft.AspNetCore.Http
@using System;
@using System.Collections.Generic;
@using System.IO;
@using System.Linq;
@using System.Security.Claims;
@using System.Threading.Tasks;
@using Microsoft.AspNetCore.Mvc;
@using Microsoft.AspNetCore.Mvc.RazorPages;
@using Microsoft.Extensions.Configuration;
@using Refit;
@using Sicsoft.Checkin.Web.Models;
@using Newtonsoft.Json;

@inject IHttpContextAccessor httpContextAccessor

@{
    var Roles = ((ClaimsIdentity)User.Identity).Claims
        .Where(d => d.Type == "Roles")
        .Select(s1 => s1.Value)
        .FirstOrDefault()
        .Split("|");
}

@section styles {
    <style>
        .document-card {
            border-radius: 14px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 0;
        }

        .info-box {
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 12px;
            padding: 16px;
            height: 100%;
        }

        .totals-box {
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 12px;
            padding: 18px;
            max-width: 420px;
            margin-left: auto;
        }

            .totals-box p {
                display: flex;
                justify-content: space-between;
                margin-bottom: 8px;
            }

            .totals-box .grand-total {
                border-top: 1px solid rgba(0,0,0,.12);
                margin-top: 12px;
                padding-top: 12px;
                font-size: 22px;
                font-weight: 700;
            }

        .table th {
            white-space: nowrap;
        }
    </style>
}

@section scripts {
    <script src="/js/Documentos/NuevoDocumento.js"></script>
}

<input hidden id="Cantones" value="@JsonConvert.SerializeObject(Model.Cantones)" />
<input hidden id="Distritos" value="@JsonConvert.SerializeObject(Model.Distritos)" />
<input hidden id="Barrios" value="@JsonConvert.SerializeObject(Model.Barrios)" />
<input hidden id="Clientes" value="@JsonConvert.SerializeObject(Model.Clientes)" />
<input hidden id="Productos" value="@JsonConvert.SerializeObject(Model.Productos)" />

<input hidden id="CP" value="@JsonConvert.SerializeObject(Model.Condicion)" />
<input hidden id="Bodega" value="@JsonConvert.SerializeObject(Model.Bodega)" />
<input hidden id="Documento" value="@JsonConvert.SerializeObject(Model.Documento)" />
<input hidden id="BaseEntry" value="@JsonConvert.SerializeObject(Model.BaseEntry)" />
<input hidden id="urlGenerar" value="@Url.Page("Nuevo", "AgregarDocumento")" />
<input hidden id="urlCliente" value="@Url.Page("Nuevo", "AgregarCliente")" />
<input hidden id="urlFacturas" value="@Url.Page("Nuevo", "Facturas")" />

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Documentos</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Generar Documento</li>
            </ol>
        </nav>
    </div>

    <div class="ms-auto">
        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm">
            Regresar
        </a>
    </div>
</div>

<div class="card document-card mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div>
                <h4 class="mb-1">Generar Documento</h4>
                <p class="mb-0 text-secondary">Complete la información del documento</p>
            </div>

            <span class="badge text-bg-primary px-3 py-2">
                @DateTime.Now.ToString("dd/MM/yyyy")
            </span>
        </div>

        <hr />

        <div class="row g-3">
            <div class="col-md-3">
                <div class="info-box">
                    <label class="form-label text-secondary mb-1">Tipo</label>
                    <h5 class="mb-1">Documento</h5>
                    <small class="text-secondary">Fecha: @DateTime.Now.ToString("dd MMM yyy")</small>
                    <input hidden id="Fecha" type="datetime" value="@DateTime.Now" />
                </div>
            </div>

            <div class="col-md-3">
                <label for="selectMoneda" class="form-label">Moneda</label>
                <select class="form-control single-select select2" id="selectMoneda" onchange="javascript: onChangeMoneda()">
                    <option value="CRC" selected>CRC</option>
                </select>
            </div>

            <div class="col-md-6">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label for="ClienteSeleccionado" class="form-label mb-0">Cliente</label>
                    <a onclick="javascript: AbrirModalAgregarCliente()" class="text-success" style="cursor:pointer;">
                        <i class="fa fa-plus"></i> Agregar Cliente
                    </a>
                </div>

                <select id="ClienteSeleccionado"
                        asp-for="Documento.idCliente"
                        class="form-control single-select select2"
                        onchange="javascript: onChangeCliente()">
                    <option value="0">Seleccione Cliente</option>
                </select>

                <div class="mt-2 small">
                    <span id="spanDireccion"></span><br />
                    <strong id="strongInfo">Phone: &nbsp;&nbsp;&nbsp;&nbsp; Email:</strong>
                </div>
            </div>

            <div class="col-md-3">
                <label for="selectCondPago" class="form-label">Condición de Pago</label>
                <select class="form-control single-select select2" id="selectCondPago"></select>
            </div>

      
        </div>
    </div>
</div>

<div class="card document-card mb-3" id="boxP">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="section-title">Agregar Productos</h5>
        </div>

        <hr />

        <div class="row g-3">
            <div class="col-12">
                <label for="ProductoSeleccionado" class="form-label">Producto</label>
                <select id="ProductoSeleccionado"
                        class="form-control single-select select2"
                        onchange="javascript: onChangeProducto()">
                    <option value="0">Seleccione Productos</option>
                </select>
            </div>

            <div class="col-md-4">
                <label for="cantidad" class="form-label">Cantidad</label>
                <input type="number" class="form-control" id="cantidad" placeholder="Cantidad" value="1" />
            </div>

            <div class="col-md-4">
                <label for="descuento" class="form-label">% Descuento</label>
                <input type="number" class="form-control" id="descuento" placeholder="Descuento" value="0" />
            </div>

            <div class="col-md-4">
                <label for="inputPrecio" class="form-label">Precio de Venta</label>
                <input id="inputPrecio" type="number" class="form-control" placeholder="Precio Unitario" value="0" />
            </div>

            <div class="col-12 text-end">
                <a id="agregar"
                   onclick="javascript: AgregarProductoTabla();"
                   class="btn btn-rounded btn-outline-primary px-4">
                    + Agregar Producto
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card document-card mb-3" >
    <div class="card-body">
        <h5 class="section-title mb-3">Detalle del Documento</h5>

        <div class="table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Descripción</th>
                        <th class="text-end">Cantidad</th>
                        <th class="text-end">Precio de Venta</th>
                        <th class="text-end">% Descuento</th>
                        <th class="text-end">Descuento</th>
                        <th class="text-end">Impuesto</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Eliminar</th>
                    </tr>
                </thead>
                <tbody id="tbody"></tbody>
            </table>
        </div>

        <div class="row mt-3">
            <div class="col-md-6"></div>

            <div class="col-md-6">
                <div class="totals-box">
                    <p>
                        <span>Sub Total:</span>
                        <strong id="subG">0</strong>
                    </p>
                    <p>
                        <span>Descuento:</span>
                        <strong id="descG">0</strong>
                    </p>
                    <p>
                        <span>Impuesto:</span>
                        <strong id="impG">0</strong>
                    </p>

                    <div class="grand-total d-flex justify-content-between">
                        <span>Total:</span>
                        <span id="totG">0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card document-card">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label for="inputComentarios" class="form-label">Comentarios</label>
                <textarea id="inputComentarios" class="form-control" rows="4"></textarea>
            </div>

            <div class="col-12 text-end">
                <button type="button"
                        class="btn btn-rounded btn-outline-success px-5"
                        onclick="javascript: Generar()">
                    Generar Documento
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade bs-example-modal-lg"
     id="ModalAgregarCliente"
     tabindex="-1"
     role="dialog"
     aria-labelledby="myLargeModalLabel"
     aria-hidden="true"
     style="display: none;">

    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Cliente</h5>
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
            </div>

            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label for="selectTP" class="form-label">Tipo de Cédula</label>
                        <select id="selectTP" class="form-control" onchange="javascript: maskCedula();" required>
                            <option value="01">Nacional</option>
                            <option value="02">Jurídica</option>
                            @if (!string.IsNullOrEmpty(Roles.Where(a => a == "55").FirstOrDefault()))
                            {
                                <option value="03">DIMEX</option>
                                <option value="04">NITE</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label for="Cedula" class="form-label">Cédula <span class="text-danger">*</span></label>
                        <input type="text"
                               id="Cedula"
                               class="form-control"
                               required
                               maxlength="12"
                               onchange="javascript: BuscarCliente()"
                               onblur="javascript: validarCedula()" />
                    </div>

                    <div class="col-md-4">
                        <label for="Nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" id="Nombre" readonly class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label for="Email" class="form-label">Correo Factura <span class="text-danger">*</span></label>
                        <input type="text" id="Email" class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label for="Telefono" class="form-label">Teléfono <span class="text-danger">*</span></label>
                        <input type="text" id="Telefono" class="form-control" required />
                    </div>

                    <div class="col-md-3">
                        <label for="selectP" class="form-label">Provincia</label>
                        <select id="selectP" class="form-control" onchange="javascript: ModificaSelects(1)" required>
                            <option value="1" selected>San José</option>
                            <option value="2">Alajuela</option>
                            <option value="3">Cartago</option>
                            <option value="4">Heredia</option>
                            <option value="5">Guanacaste</option>
                            <option value="6">Puntarenas</option>
                            <option value="7">Limón</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label for="selectC" class="form-label">Cantón</label>
                        <select id="selectC" class="form-control" onchange="javascript: ModificaSelects(2)" required>
                            @foreach (var item in Model.Cantones)
                            {
                                <option value="@item.CodCanton">@item.NomCanton</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label for="selectD" class="form-label">Distrito</label>
                        <select id="selectD" class="form-control" onchange="javascript: ModificaSelects(3)" required>
                            @foreach (var item in Model.Distritos)
                            {
                                <option value="@item.CodDistrito">@item.NomDistrito</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label for="selectB" class="form-label">Barrio</label>
                        <select id="selectB" class="form-control" required>
                            @foreach (var item in Model.Barrios)
                            {
                                <option value="@item.CodBarrio">@item.NomBarrio</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label for="Sennas" class="form-label">Dirección <span class="text-danger">*</span></label>
                        <input type="text" id="Sennas" class="form-control" required />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-rounded btn-outline-danger"
                        data-dismiss="modal">
                    Cancelar
                </button>

                <button type="button"
                        class="btn btn-rounded btn-outline-primary"
                        onclick="javascript: AgregarCliente();">
                    Agregar
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function maskCedula() {
        $("#Telefono").mask("9999-9999");
        var TC = $("#selectTP").val();

        switch (TC) {
            case "01":
                $("#Cedula").mask("999999999");
                break;

            case "02":
                $("#Cedula").mask("9999999999");
                break;
        }
    }

    function validarCedula() {
        var TC = $("#selectTP").val();

        switch (TC) {
            case "01":
                if ($("#Cedula").val().length < 9) {
                    $("#Cedula").focus();
                    $("#Cedula").select();
                }
                break;

            case "02":
                if ($("#Cedula").val().length < 10) {
                    $("#Cedula").focus();
                    $("#Cedula").select();
                }
                break;
        }
    }
</script>