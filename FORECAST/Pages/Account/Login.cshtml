@page
@model Sicsoft.Checkin.Web.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html data-bs-theme="light">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Inicio de Sesión</title>
    <link rel="icon" href="~/assets/images/favicon-32x32.png" type="image/png" />

    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        html,
        body {
            height: 100%;
            margin: 0;
            background: #f4f6f8 !important;
            font-family: 'Noto Sans', sans-serif;
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px;
            background: #f4f6f8;
        }

        .login-container {
            width: 100%;
            max-width: 1080px;
            min-height: 620px;
            background: #ffffff;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.10);
            display: grid;
            grid-template-columns: 56% 44%;
        }

        .login-visual {
            position: relative;
            background-image: url('/img/LOCAL.jpeg');
            background-size: cover;
            background-position: center;
        }

            .login-visual::after {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient( 180deg, rgba(8, 38, 74, 0.15), rgba(8, 38, 74, 0.45) );
            }

        .visual-caption {
            position: absolute;
            left: 42px;
            bottom: 42px;
            right: 42px;
            z-index: 2;
            color: #ffffff;
        }

            .visual-caption h1 {
                font-size: 34px;
                font-weight: 700;
                margin-bottom: 12px;
            }

            .visual-caption p {
                font-size: 15px;
                line-height: 1.6;
                margin: 0;
                max-width: 460px;
                color: rgba(255, 255, 255, 0.90);
            }

        .login-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 56px 48px;
        }

        .login-box {
            width: 100%;
            max-width: 380px;
        }

        .login-logo {
            width: 180px;
            max-width: 100%;
            display: block;
            margin-bottom: 34px;
        }

        .login-title {
            color: #1f2937;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .login-description {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 32px;
        }

        .form-label {
            font-size: 14px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
        }

        .form-control {
            height: 50px;
            border-radius: 10px;
            border: 1px solid #d1d5db;
            font-size: 14px;
            padding: 12px 14px;
            color: #111827;
        }

            .form-control:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
            }

        .input-group .form-control {
            border-right: 0;
        }

        .input-group-text {
            border-radius: 0 10px 10px 0;
            border: 1px solid #d1d5db;
            border-left: 0;
            background: #ffffff;
            color: #6b7280;
        }

        .form-check-label {
            color: #6b7280;
            font-size: 14px;
        }

        .btn-login {
            height: 50px;
            border-radius: 10px;
            background: #2563eb;
            border-color: #2563eb;
            font-size: 15px;
            font-weight: 700;
        }

            .btn-login:hover {
                background: #1d4ed8;
                border-color: #1d4ed8;
            }

        .login-footer {
            margin-top: 32px;
            color: #9ca3af;
            font-size: 12px;
        }

        .text-danger.validation-summary-errors,
        .validation-summary-errors {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626 !important;
            border-radius: 10px;
            padding: 10px 12px;
            font-size: 13px;
            margin-bottom: 18px;
        }

        @@media (max-width: 900px) {
            .login-container {
                grid-template-columns: 1fr;
                max-width: 460px;
                min-height: auto;
            }

            .login-visual {
                display: none;
            }

            .login-panel {
                padding: 42px 28px;
            }

            .login-logo {
                margin-left: auto;
                margin-right: auto;
            }

            .login-title,
            .login-description,
            .login-footer {
                text-align: center;
            }
        }
    </style>
</head>

<body>
    <main class="login-wrapper">
        <section class="login-container">

            <div class="login-visual">
                <div class="visual-caption">
                    <h1>Moto Repuestos Rojas</h1>
                    <p>
                        Accede al sistema para administrar tus procesos de forma rápida,
                        ordenada y eficiente.
                    </p>
                </div>
            </div>

            <div class="login-panel">
                <div class="login-box">
                    <img src="/img/logo.png" class="login-logo" alt="Logo">

                    <h2 class="login-title">Iniciar sesión</h2>
                    <p class="login-description">
                        Ingresa con tu usuario y contraseña.
                    </p>

                    <form class="row g-3" method="post" id="formTipos" role="form" novalidate>
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="col-12">
                            <label for="correoElectronico" class="form-label">Usuario</label>
                            <input type="email"
                                   class="form-control"
                                   asp-for="Input.nombreUsuario"
                                   id="correoElectronico"
                                   placeholder="Usuario o correo electrónico">
                        </div>

                        <div class="col-12">
                            <label for="pwd" class="form-label">Contraseña</label>
                            <div class="input-group" id="show_hide_password">
                                <input type="password"
                                       class="form-control"
                                       asp-for="Input.clave"
                                       id="pwd"
                                       placeholder="Contraseña">
                                <a href="javascript:;" class="input-group-text">
                                    <i class="bi bi-eye-slash-fill"></i>
                                </a>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="basic_checkbox_1">
                                <label class="form-check-label" for="basic_checkbox_1">
                                    Recordarme
                                </label>
                            </div>
                        </div>

                        <div class="col-12 mt-2">
                            <button type="submit" class="btn btn-primary btn-login w-100">
                                Ingresar
                            </button>
                        </div>
                    </form>

                    <div class="login-footer">
                        © @DateTime.Now.Year Grupo 7. Todos los derechos reservados.
                    </div>
                </div>
            </div>

        </section>
    </main>

    <script src="~/assets/js/jquery.min.js"></script>
    <script src="~/js/Login/Login.js"></script>

    <script>
        $(document).ready(function () {
            $("#show_hide_password a").on('click', function (event) {
                event.preventDefault();

                const input = $('#show_hide_password input');
                const icon = $('#show_hide_password i');

                if (input.attr("type") === "text") {
                    input.attr('type', 'password');
                    icon.removeClass("bi-eye-fill").addClass("bi-eye-slash-fill");
                } else {
                    input.attr('type', 'text');
                    icon.removeClass("bi-eye-slash-fill").addClass("bi-eye-fill");
                }
            });
        });
    </script>
</body>
</html>