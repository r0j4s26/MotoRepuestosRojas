@page
@model MotoRepuestosRojas.Pages.Ofertas.IndexModel
@{
    ViewData["Title"] = "Cotizaciones";

    NumberFormatInfo formato = new CultureInfo("es-CR").NumberFormat;
    formato.CurrencySymbol = "";
    formato.CurrencyGroupSeparator = ",";
    formato.NumberDecimalSeparator = ".";
}
@using System.Globalization;
@using Microsoft.AspNetCore.Http
@using System;
@using System.Collections.Generic;
@using System.IO;
@using System.Linq;
@using System.Security.Claims;
@using System.Threading.Tasks;
@using Microsoft.AspNetCore.Mvc;
@using Microsoft.AspNetCore.Mvc.RazorPages;
@using Microsoft.Extensions.Configuration;
@using Refit;
@inject IHttpContextAccessor httpContextAccessor

@{
    var Roles = ((ClaimsIdentity)User.Identity).Claims.Where(d => d.Type == "Roles").Select(s1 => s1.Value).FirstOrDefault().Split("|");
}

@section styles {
}

@section scripts {
    <script>
        $(document).ready(function () {
            $('.select2').select2();

            $(".js-example-responsive").select2({
                width: 'resolve',
                height: 'resolve'
            });
        });
    </script>
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Cotizaciones</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Listado Cotizaciones</li>
            </ol>
        </nav>
    </div>
    <div class="ms-auto">
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="card-title">
            <div class="row">
                <div class="col-sm-6">
                    <h4 class="mb-0">Filtro</h4>
                </div>

                <div class="col-sm-6 text-end">
                    <a asp-page="./Nuevo" class="btn btn-rounded btn-outline-primary" title="Agregar">
                        + Agregar
                    </a>
                </div>
            </div>
        </div>

        <hr />

        <form method="get">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-group">
                        <label for="FecInicial" class="form-label">Fecha Inicial</label>
                        <div class="input-group">
                            <input class="form-control border-start-0" id="FecInicial" type="date" asp-for="filtro.FechaInicial">
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-group">
                        <label for="FecFinal" class="form-label">Fecha Final</label>
                        <div class="input-group">
                            <input class="form-control border-start-0" id="FecFinal" type="date" asp-for="filtro.FechaFinal">
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-group">
                        <label for="ClienteF" class="form-label">Cliente</label>
                        <div class="input-group">
                            <select class="form-control single-select select2" id="ClienteF" asp-for="filtro.Codigo1" required>
                                <option value="0">Seleccione</option>
                                @foreach (var item in Model.Clientes)
                                {
                                    <option value="@item.id">@item.id - @item.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-group">
                        <label for="Estado" class="form-label">Estado</label>
                        <div class="input-group">
                            <select class="form-control single-select select2" id="Estado" asp-for="filtro.ItemCode" required>
                                <option value="0">Abierta</option>
                                <option value="1">Cerrada</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <button title="Buscar" type="submit" class="btn btn-rounded btn-outline-primary">
                        Buscar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="card-title">
            <div class="row">
                <div class="col-sm-6">
                    <h4 class="mb-0">Listado de Cotizaciones</h4>
                </div>
            </div>
        </div>

        <hr />

        <div class="table-responsive">
            <table class="table table-striped table-bordered datatable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Fecha Creado</th>
                        <th>Condición Pago</th>
                        <th>Moneda</th>
                        <th>SubTotal</th>
                        <th>Descuento</th>
                        <th>Impuesto</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.Listas)
                    {
                        <tr>
                            <td>@item.id</td>

                            <td align="left" style="padding-top:15px;">
                                <a style="font-size:15px;">
                                    @(Model.Clientes.Where(a => a.id == item.idCliente).FirstOrDefault() == null ? "Cliente Inexistente" : Model.Clientes.Where(a => a.id == item.idCliente).FirstOrDefault().id + " - " + Model.Clientes.Where(a => a.id == item.idCliente).FirstOrDefault().Nombre)
                                </a>
                            </td>

                            <td align="left" style="padding-top:15px;">
                                @item.Fecha.ToString("dd/MM/yyyy")
                            </td>

                            <td align="left" style="padding-top:15px;">
                                @(Model.Condicion.Where(a => a.id == item.idCondPago).FirstOrDefault() == null ? "" : Model.Condicion.Where(a => a.id == item.idCondPago).FirstOrDefault().Nombre)
                            </td>

                            <td align="left" style="padding-top:15px;">
                                @item.Moneda
                            </td>

                            <td align="left" style="padding-top:15px;">
                                @Math.Round(item.Subtotal, 2).ToString("C", formato)
                            </td>

                            <td align="left" style="padding-top:15px;">
                                @Math.Round(item.TotalDescuentos, 2).ToString("C", formato)
                            </td>

                            <td align="left" style="padding-top:15px;">
                                @Math.Round(item.TotalImpuestos, 2).ToString("C", formato)
                            </td>

                            <td align="left" style="padding-top:15px;">
                                @Math.Round(item.TotalCompra, 2).ToString("C", formato)
                            </td>

                            @if (item.Status == "0")
                            {
                                <td align="center" style="padding-top:15px;">
                                    <span class="btn btn-success">Abierto</span>
                                </td>
                            }
                            else
                            {
                                <td align="center" style="padding-top:15px;">
                                    <span class="btn btn-danger">Cerrado</span>
                                </td>
                            }

                            <td align="center" style="padding-top:15px;">
                                @if (item.Status == "0" && !string.IsNullOrEmpty(Roles.Where(a => a == "1").FirstOrDefault()))
                                {
                                    <a asp-page="./Editar"
                                       asp-route-id="@item.id"
                                       class="btn btn-rounded btn-outline-warning">
                                        Editar
                                    </a>
                                    <text>&nbsp;</text>
                                }

                                <a asp-page="./Observar"
                                   asp-route-id="@item.id"
                                   class="btn btn-rounded btn-outline-info">
                                    Observar
                                </a>
                                &nbsp;

                                @if (item.Status == "0" && !string.IsNullOrEmpty(Roles.Where(a => a == "21").FirstOrDefault()))
                                {
                                    <a asp-page="/Documentos/Nuevo"
                                       asp-route-id="@item.id"
                                       title="Generar Venta"
                                       class="btn btn-rounded btn-outline-success">
                                        Generar Venta
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Fecha Creado</th>
                        <th>Condición Pago</th>
                        <th>Moneda</th>
                        <th>SubTotal</th>
                        <th>Descuento</th>
                        <th>Impuesto</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>