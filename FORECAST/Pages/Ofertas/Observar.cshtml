@page "{id}"
@using System.Globalization
@using Microsoft.AspNetCore.Http
@using System;
@using System.Collections.Generic;
@using System.IO;
@using System.Linq;
@using System.Security.Claims;
@using System.Threading.Tasks;
@using Microsoft.AspNetCore.Mvc;
@using Microsoft.AspNetCore.Mvc.RazorPages;
@using Microsoft.Extensions.Configuration;
@using Refit;
@using Sicsoft.Checkin.Web.Models;
@using Newtonsoft.Json;
@model MotoRepuestosRojas.Pages.Ofertas.ObservarModel
@inject IHttpContextAccessor httpContextAccessor

@{
    ViewData["Title"] = "Cotizaciones";

    NumberFormatInfo formato = new CultureInfo("es-CR").NumberFormat;
    formato.CurrencySymbol = "";
    formato.CurrencyGroupSeparator = ",";
    formato.NumberDecimalSeparator = ".";

    var condicionPago = Model.Condicion.FirstOrDefault(a => a.id == Model.Oferta.idCondPago);
    var cliente = Model.Clientes.FirstOrDefault(a => a.id == Model.Oferta.idCliente);
}

@section styles {
    <style>
        .html {
            background: #fff !important;
            color: #000 !important;
            font-family: Arial, Helvetica, sans-serif;
        }

            .html .card {
                border: 1px solid #000 !important;
                box-shadow: none !important;
                background: #fff !important;
            }

            .html .card-header {
                background: #f2f2f2 !important;
                color: #000 !important;
                border-bottom: 2px solid #000 !important;
                font-weight: bold;
            }

            .html table {
                width: 100%;
                border-collapse: collapse;
            }

                .html table th {
                    background: #d9d9d9 !important;
                    color: #000 !important;
                    border: 1px solid #000 !important;
                    padding: 8px;
                }

                .html table td {
                    border: 1px solid #000 !important;
                    color: #000 !important;
                    padding: 8px;
                }

            .html h1,
            .html h2,
            .html h3,
            .html h4,
            .html h5,
            .html h6,
            .html p,
            .html span,
            .html strong,
            .html label {
                color: #000 !important;
            }

            .html .text-secondary,
            .html .text-muted,
            .html .text-body-secondary {
                color: #000 !important;
            }

            .html .badge {
                background: #000 !important;
                color: #fff !important;
            }
    </style>
    <style>
        .orden-info-card {
            border: 1px solid var(--bs-border-color);
            border-radius: 14px;
            padding: 1rem;
            height: 100%;
            background: var(--bs-body-bg);
        }

        .orden-info-card .label {
            color: var(--bs-secondary-color);
            font-size: .82rem;
            margin-bottom: .25rem;
        }

        .orden-info-card .value {
            font-weight: 700;
            margin-bottom: 0;
        }

        .orden-total-box {
            max-width: 360px;
            margin-left: auto;
            border: 1px solid var(--bs-border-color);
            border-radius: 14px;
            padding: 1rem;
            background: rgba(var(--bs-primary-rgb), .04);
        }

        .orden-total-row {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: .55rem;
        }

        .orden-total-row.total {
            border-top: 1px solid var(--bs-border-color);
            padding-top: .8rem;
            margin-top: .8rem;
            font-size: 1.2rem;
            font-weight: 800;
        }

        .table thead th {
            white-space: nowrap;
        }

        .comentario-box {
            min-height: 90px;
            border: 1px dashed var(--bs-border-color);
            border-radius: 14px;
            padding: 1rem;
            background: var(--bs-body-bg);
        }
    </style>
}

@section scripts {
    <script>
        function ImprimirPantalla() {
            try {
                const html = $(".html").html();

                html2pdf(html, {
                    margin: 1,
                    padding: 0,
                    filename: 'Orden.pdf',
                    image: { type: 'jpeg', quality: 1 },
                    html2canvas: { scale: 2, logging: true },
                    jsPDF: { unit: 'in', format: 'A2', orientation: 'P' },
                    class: ImprimirPantalla
                });
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e
                });
            }
        }
    </script>
}

<main class="main-wrapper">
    <div class="main-content">

        <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
            <div class="breadcrumb-title pe-3">Ordenes</div>
            <div class="ps-3">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 p-0">
                        <li class="breadcrumb-item">
                            <a href="#"><i class="bx bx-home-alt"></i></a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Observar Orden</li>
                    </ol>
                </nav>
            </div>

            <div class="ms-auto d-flex gap-2">
                <a asp-page="./Index" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1">
                    <span class="material-icons-outlined fs-6">arrow_back</span>
                    Regresar
                </a>

                <button id="print" class="btn btn-warning btn-sm d-inline-flex align-items-center gap-1" type="button" onclick="ImprimirPantalla()">
                    <span class="material-icons-outlined fs-6">print</span>
                    Imprimir
                </button>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h6 class="mb-0 text-uppercase">Observar Orden</h6>
                <span class="badge text-bg-primary">Orden No: @Model.Oferta.id</span>
            </div>

            <div class="card-body">
                <div class="row g-3 mb-4">
                    <div class="col-12 col-xl-4">
                        <div class="orden-info-card">
                            <p class="label">Cliente</p>
                            <h5 class="mb-0 text-primary">
                                @(cliente == null ? "Cliente Inexistente" : cliente.id + " - " + cliente.Nombre)
                            </h5>
                        </div>
                    </div>

                    <div class="col-6 col-md-3 col-xl-2">
                        <div class="orden-info-card">
                            <p class="label">Fecha</p>
                            <p class="value">@Model.Oferta.Fecha.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>

                    <div class="col-6 col-md-3 col-xl-2">
                        <div class="orden-info-card">
                            <p class="label">Moneda</p>
                            <p class="value">@Model.Oferta.Moneda</p>
                        </div>
                    </div>

                    <div class="col-6 col-md-3 col-xl-2">
                        <div class="orden-info-card">
                            <p class="label">Condición Pago</p>
                            <p class="value">@(condicionPago == null ? "" : condicionPago.Nombre)</p>
                        </div>
                    </div>

                 
                </div>

                <div class="table-responsive mb-4">
                    <table class="table table-striped table-bordered align-middle w-100">
                        <thead>
                            <tr>
                                <th class="text-center">#</th>
                                <th class="text-center">Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-center">Precio Unitario</th>
                                <th class="text-center">% Descuento</th>
                                <th class="text-center">Descuento</th>
                                <th class="text-center">Impuesto</th>
                                <th class="text-center">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Oferta.Detalle)
                            {
                                var producto = Model.Productos.FirstOrDefault(a => a.id == item.idProducto);
                                var nombreProducto = producto == null
                                ? "Producto Inexistente"
                                : (producto.Stock <= 0 ? "*" : "") + producto.Codigo + " - " + producto.Nombre;

                                <tr>
                                    <td class="text-center">@item.NumLinea</td>
                                    <td>@nombreProducto</td>
                                    <td class="text-end">@(Math.Round(item.Cantidad, 2).ToString("C", formato))</td>
                                    <td class="text-end">@Math.Round(item.PrecioUnitario, 2).ToString("C", formato)</td>
                                    <td class="text-center">@Math.Round(item.PorDescto)%</td>
                                    <td class="text-end">@Math.Round(item.Descuento, 2).ToString("C", formato)</td>
                                    <td class="text-end">@Math.Round(item.TotalImpuesto, 2).ToString("C", formato)</td>
                                    <td class="text-end fw-semibold">@Math.Round(item.TotalLinea, 2).ToString("C", formato)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="orden-total-box mb-4">
                    <div class="orden-total-row">
                        <span>Sub Total</span>
                        <strong>@Math.Round(Model.Oferta.Subtotal, 2).ToString("C", formato)</strong>
                    </div>
                    <div class="orden-total-row">
                        <span>Descuento</span>
                        <strong>@Math.Round(Model.Oferta.TotalDescuentos, 2).ToString("C", formato)</strong>
                    </div>
                    <div class="orden-total-row">
                        <span>Impuesto</span>
                        <strong>@Math.Round(Model.Oferta.TotalImpuestos, 2).ToString("C", formato)</strong>
                    </div>
                    <div class="orden-total-row total text-primary">
                        <span>Total</span>
                        <span>@Math.Round(Model.Oferta.TotalCompra, 2).ToString("C", formato)</span>
                    </div>
                </div>

                <div class="card border shadow-none mb-0">
                    <div class="card-header bg-transparent">
                        <h6 class="mb-0">Comentarios</h6>
                    </div>
                    <div class="card-body">
                        <div class="comentario-box">
                            @(string.IsNullOrWhiteSpace(Model.Oferta.Comentarios) ? "Sin comentarios" : Model.Oferta.Comentarios)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Imprimir -->
<div class="html" hidden>
    <div class="row">
        <div class="col-12">
            <h2>Orden No: @Model.Oferta.id</h2>
        </div>

        <div class="col-3">
            <h5><b>Fecha:</b> @Model.Oferta.Fecha.ToString("dd/MM/yyyy")</h5>
        </div>

        <div class="col-3">
            <h5><b>Moneda:</b> @Model.Oferta.Moneda</h5>
        </div>

        <div class="col-3">
            <h5><b>Condición Pago:</b> @(condicionPago == null ? "" : condicionPago.Nombre)</h5>
        </div>



        <div class="col-12">
            <h4><b>Cliente:</b> @(cliente == null ? "Cliente Inexistente" : cliente.id + " - " + cliente.Nombre)</h4>
        </div>
    </div>

    <div class="row">
        <div class="col-12 table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th class="text-center">#</th>
                        <th class="text-center">Producto</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-center">Precio Unitario</th>
                        <th class="text-center">% Descuento</th>
                        <th class="text-center">Descuento</th>
                        <th class="text-center">Impuesto</th>
                        <th class="text-center">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Oferta.Detalle)
                    {
                        var producto = Model.Productos.FirstOrDefault(a => a.id == item.idProducto);
                        var nombreProducto = producto == null
                        ? "Producto Inexistente"
                        : (producto.Stock <= 0 ? "*" : "") + producto.Codigo + " - " + producto.Nombre;

                        <tr>
                            <td>@item.NumLinea</td>
                            <td>@nombreProducto</td>
                            <td class="text-right">@(Math.Round(item.Cantidad, 2).ToString("C", formato))</td>
                            <td class="text-center">@Math.Round(item.PrecioUnitario, 2).ToString("C", formato)</td>
                            <td class="text-center">@Math.Round(item.PorDescto)%</td>
                            <td class="text-center">@Math.Round(item.Descuento, 2).ToString("C", formato)</td>
                            <td class="text-center">@Math.Round(item.TotalImpuesto, 2).ToString("C", formato)</td>
                            <td class="text-center">@Math.Round(item.TotalLinea, 2).ToString("C", formato)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-12 text-right">
            <p>Sub Total: <span>@Math.Round(Model.Oferta.Subtotal, 2).ToString("C", formato)</span></p>
            <p>Descuento: <span>@Math.Round(Model.Oferta.TotalDescuentos, 2).ToString("C", formato)</span></p>
            <p>Impuesto: <span>@Math.Round(Model.Oferta.TotalImpuestos, 2).ToString("C", formato)</span></p>
            <h3><b>Total:</b> <span>@Math.Round(Model.Oferta.TotalCompra, 2).ToString("C", formato)</span></h3>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <h4>Comentarios</h4>
            <p>@Model.Oferta.Comentarios</p>
        </div>
    </div>
</div>
