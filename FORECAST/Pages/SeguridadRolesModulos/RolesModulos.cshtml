@page
@model FORECAST.Pages.SeguridadRolesModulos.RolesModulosModel
@{
    ViewData["Title"] = "Roles";
}

@section styles {


}

@section scripts {

    <script>
        try {
            $(document).ready(function () {
                jQuery(document).ready(function ($) {
                    $(document).ready(function () {
                        $('.mi-selector').select2();
                    });
                });
                $(".js-example-responsive").select2({
                    width: 'resolve',// need to override the changed default
                    height: 'resolve'
                });

                RellenaDatosAsignados();

            });
        } catch (e) {
            console.log(e);
            Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: 'Ha ocurrido un error al intentar imprimir ' + e

            })
        }
        var ProdCadena = [];
        var ProdCadenaM = [];

        function InsertarProductoTablaMia(i) {
            try {
                var detalle =
                {
                    codModulo: ProdCadena[i].codModulo,
                    descripcion: ProdCadena[i].descripcion
                }
                ProdCadenaM.push(detalle);

                ProdCadena.splice(i, 1);
                RellenaTablaM();
                RellenaTablaG();

            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }

        function InsertarProductoTablaG(i) {
            try {
                var detalle =
                {
                    codModulo: ProdCadenaM[i].codModulo,
                    descripcion: ProdCadenaM[i].descripcion
                }
                ProdCadena.push(detalle);

                ProdCadenaM.splice(i, 1);
                RellenaTablaM();
                RellenaTablaG();
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }

        function RellenaDatosAsignados() {
            try {


                $.ajax({
                    type: 'GET',
                    dataType: 'json',
                    url: '@Url.Page("RolesModulos", "Modulos")',
                    data: { id: $("#CodRol").val() },
                    success: function (result) {

                        console.log(result);



                        for (var i = 0; i < result.modulosGenerales.length; i++) {
                            var detalle = {
                                codModulo: result.modulosGenerales[i].codModulo,
                                descripcion: result.modulosGenerales[i].descripcion,

                            };
                            ProdCadena.push(detalle);

                        }

                        for (var i = 0; i < result.modulosMiosS.length; i++) {
                            if (result.modulosMiosS[i].descripcion != null) {

                                var detalle = {
                                    codModulo: result.modulosMiosS[i].codModulo,
                                    descripcion: result.modulosMiosS[i].descripcion,

                                };
                                ProdCadenaM.push(detalle);
                            }

                        }
                        RellenaTablaG();
                        RellenaTablaM();


                    },
                    beforeSend: function () {

                    },
                    complete: function () {

                    }
                });
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }

        function RellenaTablaG() {
            try {
                var sOptions = '';

                $("#tbody1").html('');

                for (var i = 0; i < ProdCadena.length; i++) {
                    sOptions += '<tr>'
                    sOptions += '<td align="center" style="padding-top:15px;">  <p style="font-size:15px;">' + ProdCadena[i].codModulo + '</p></td>';
                    sOptions += '<td align="left" style="padding-top:15px;">  <p style="font-size:15px;">' + ProdCadena[i].descripcion + '</p></td>';

                    sOptions += '<td align="center" style="padding-top:15px;"><a  onclick="javascript: InsertarProductoTablaMia(' + i + ')" title="Pasar Modulo" class="fa fa-mail-forward icono"></a> ';



                    sOptions += '</tr>'
                }
                $("#tbody1").html(sOptions);
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }


        function RellenaTablaM() {
            try {
                var sOptions = '';

                $("#tbody2").html('');

                for (var i = 0; i < ProdCadenaM.length; i++) {
                    sOptions += '<tr>'
                    sOptions += '<td align="center" style="padding-top:15px;">  <p style="font-size:15px;">' + ProdCadenaM[i].codModulo + '</p></td>';
                    sOptions += '<td align="left" style="padding-top:15px;">  <p style="font-size:15px;">' + ProdCadenaM[i].descripcion + '</p></td>';

                    sOptions += '<td align="center" style="padding-top:15px;"><a  onclick="javascript: InsertarProductoTablaG(' + i + ')" title="Pasar Modulo" class="fa fa-mail-reply icono"></a> ';



                    sOptions += '</tr>'
                }
                $("#tbody2").html(sOptions);
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }

        function Generar() {
            try {
                var CodRol = $("#CodRol").val();

                for (var i = 0; i < ProdCadenaM.length; i++) {
                    ProdCadenaM[i].descripcion = ProdCadenaM[i].descripcion.replace(" ", "_");
                }
                var rolesMod =
                {
                    ProdCadenaM
                };
                var modulos = JSON.stringify(rolesMod);


                var enviar = {
                    CodRol,
                    modulos
                };
                var str = JSON.stringify(enviar).toString();
                str = str.replace(" ", "_");
                console.log(str);


                $.ajax({
                    type: 'POST',

                    url: '@Url.Page("RolesModulos", "Generar")',
                    dataType: 'text',
                    data: { recibidos: str },
                    headers: {
                        RequestVerificationToken: $('input:hidden[name="__RequestVerificationToken"]').val()
                    },
                    success: function (json) {

                        $("#divProcesando").hide();

                        if ($('.modal-backdrop').is(':visible')) {

                            $('body').removeClass('modal-open');
                            $('.modal-backdrop').hide();
                        }
                        console.log("resultado " + json);
                        if (json == "true") {
                            Swal.fire({
                                title: "Ha sido guardado con éxito",

                                icon: 'success',
                                showCancelButton: false,

                                confirmButtonText: 'OK',
                                customClass: {
                                    confirmButton: 'swalBtnColor',

                                },
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    location.reload();
                                }
                            })

                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Oops...',
                                text: 'Ha ocurrido un error al intentar guardar'

                            })
                        }
                    },

                    beforeSend: function (xhr) {

                        $("#divProcesando").modal("show");
                    },
                    complete: function () {

                    },
                    error: function (error) {

                    }
                });

            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }


        function PasarTodasDerecha() {
            try {
                var tam = ProdCadenaM.length;
                var tam2 = ProdCadena.length;


                for (var i = 0; i < ProdCadena.length; i++) {

                    var detalle =
                    {
                        codModulo: ProdCadena[i].codModulo,
                        descripcion: ProdCadena[i].descripcion
                    }
                    ProdCadenaM.push(detalle);
                }

                ProdCadena = [];


                RellenaTablaM();
                RellenaTablaG();
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }


        function PasarTodasIzquierda() {
            try {
                var tam = ProdCadena.length;
                var tam2 = ProdCadenaM.length;

                console.log(tam2);
                for (var i = 0; i < tam2; i++) {

                    var detalle =
                    {
                        codModulo: ProdCadenaM[i].codModulo,
                        descripcion: ProdCadenaM[i].descripcion
                    }
                    ProdCadena.push(detalle);
                }


                ProdCadenaM = [];


                RellenaTablaM();
                RellenaTablaG();
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e

                })
            }
        }

        function cerrarModalError() {
            $("#Error").hide();
        }

    </script>
}

}
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Roles</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Asignar Roles</li>
            </ol>
        </nav>
    </div>
    <div class="ms-auto">
    </div>
</div>
<div class="card">
    <div class="card-body">
        <div class="card-title">
            <div class="row">
                <div class="col-sm-6">
                    <h4 class="mb-0">Asignar Roles</h4>
                </div>
                <div class="col-sm-6">
                    <a asp-page="./Index" class="btn btn-outline-light btn-sm float-end me-3" style="text-decoration: underline;"><i class="lni lni-reply"></i>  Regresar</a>
                </div>
            </div>

        </div>
        <hr />

        <input id="CodRol" asp-for="Roles.idRol" hidden />
        <div class="row g-3">
            <div class="col-md-8">
                <div class="form-group">
                    <label for="desc" class="form-label">Descripción</label>
                    <div class="input-group">

                        <input type="text" class="form-control border-start-0" id="desc" placeholder="Nombre" readonly disabled asp-for="Roles.NombreRol">
                    </div>

                </div>
            </div>

        </div>


    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-sm-8">

                        <h5 class="title"> Módulos Disponibles</h5>
                    </div>

                    <div class="col-sm-3">
                        <a onclick="javascript: PasarTodasDerecha()" style="cursor: pointer; font-size: 25px; line-height: 0px;" title="Pasar Todos los Modulos"> >> </a>
                    </div>


                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive tableFixHead" style="padding:inherit; overflow:scroll;    z-index: 5; height: 290px;">
                    <table class="table table-striped">
                        <thead>
                            <tr>

                                <th align="center" style=" text-align: center;">Código</th>
                                <th align="center" style=" text-align: center;">Nombre </th>




                                <th align="center" style=" text-align: center;">Acción</th>
                            </tr>

                        </thead>
                        <tbody id="tbody1">
                        </tbody>
                    </table>

                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <div class="row">
                    <div class="col-sm-8">

                        <h5 class="title"> Módulos Asignados al Rol</h5>
                    </div>

                    <div class="col-sm-4" style="text-align: right;">
                        <a onclick="javascript: PasarTodasIzquierda()" style="cursor: pointer; font-size: 25px; line-height: 0px;" title="Pasar Todos los Modulos"><<</a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive tableFixHead" style="padding:inherit; overflow:scroll;    z-index: 5; height: 290px;">
                    <table class="table table-striped">
                        <thead>
                            <tr>

                                <th align="center" style=" text-align: center;">Código</th>
                                <th align="center" style=" text-align: center;">Nombre </th>




                                <th align="center" style=" text-align: center;">Acción</th>
                            </tr>

                        </thead>
                        <tbody id="tbody2">
                        </tbody>
                    </table>

                </div>



            </div>
        </div>
    </div>
    <div class="col-12">
        <button type ="button" onclick="javascript: Generar();" class="btn btn-rounded btn-outline-success px-5">Guardar</button>
    </div>
</div>


