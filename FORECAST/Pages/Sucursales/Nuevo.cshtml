@page
@model FORECAST.Pages.Sucursales.NuevoModel
@{
    ViewData["Title"] = "Sucursales";
}

@section styles {


}

@section scripts {



}
<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Sucursales</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Agregar Sucursales</li>
            </ol>
        </nav>
    </div>
    <div class="ms-auto">
    </div>
</div>
<div class="card">
    <div class="card-body">
        <div class="card-title">
            <div class="row">
                <div class="col-sm-6">
                    <h4 class="mb-0">Agregar Sucursales</h4>
                </div>
                <div class="col-sm-6">
                    <a asp-page="./Index" class="btn btn-outline-light btn-sm float-end me-3" style="text-decoration: underline;"><i class="lni lni-reply"></i>  Regresar</a>
                </div>
            </div>

        </div>
        <hr />
        <form method="post" id="formTipos" role="form" novalidate class="needs-validation  " enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-8">
                    <div class="form-group">
                        <label for="desc" class="form-label">Nomenclatura</label>
                        <div class="input-group">

                            <input type="text" class="form-control border-start-0" id="nombre" placeholder="Nombre" asp-for="Objeto.Nomenclatura">
                        </div>

                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group">
                        <label for="desc" class="form-label">Skey</label>
                        <div class="input-group">

                            <input type="text" class="form-control border-start-0" id="skey" placeholder="Skey" asp-for="Objeto.Skey">
                        </div>

                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-group">
                        <label for="desc" class="form-label">Meses Bloqueo</label>
                        <div class="input-group">

                            <input type="number" class="form-control border-start-0" id="MesesBloqueo" placeholder="MesesBloqueo" asp-for="Objeto.MesesBloqueo">
                        </div>

                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" id="Guardar" class="btn btn-rounded btn-outline-success px-5">Guardar</button>
                </div>
            </div>




        </form>
    </div>
</div>

