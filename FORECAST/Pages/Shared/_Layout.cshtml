    <script>
        document.addEventListener("DOMContentLoaded", function () {

            setTimeout(function () {

                // 🔥 prueba estas (una de estas es la correcta en tu template)
                document.body.classList.add("toggled");
                document.querySelector(".wrapper")?.classList.add("toggled");

            }, 200);

        });</script>
    <script>
        $(document).ready(function () {

            let temaGuardado = localStorage.getItem("theme");

            if (temaGuardado) {

                aplicarTema(temaGuardado);

                // 🔥 MARCAR EL RADIO CORRECTO
                $('#' + temaGuardado).prop('checked', true);
            }

            // 🔥 cuando cambian el tema
            $('input[name="theme-options"]').on('change', function () {

                let theme = $(this).attr('id');

                localStorage.setItem("theme", theme);

                aplicarTema(theme);
            });

        });

        function aplicarTema(theme) {
            if (theme === "LightTheme") {
                document.documentElement.setAttribute("data-bs-theme", "light");
            }
            else if (theme === "DarkTheme") {
                document.documentElement.setAttribute("data-bs-theme", "dark");
            }
            else {
                document.documentElement.setAttribute("data-bs-theme", "blue-theme");
            }
        }
    </script>
