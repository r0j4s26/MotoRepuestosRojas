<style>
    /* Footer fijo sobre el contenido (siempre visible) */
    footer.page-footer {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 1050; /* encima del contenido pero debajo de modals si es necesario */
        padding: 12px 20px;
        background: rgba(3,12,30,0.9); /* ajustá color/opa según tema */
        color: #fff;
    }

    /* Evitar que el contenido quede oculto por el footer:
       añade padding-bottom al main (igual a la altura del footer) */
    main.main-wrapper {
        padding-bottom: 60px; /* ajustá según la altura real del footer */
    }
    /* =========================
               LIGHT MODE BASE (GLOBAL)
            ========================= */
    html[data-bs-theme="light"] {
        --bg-top: #f4f6fb;
        --bg-bottom: #e9eef7;
        --text-light: #1e1e2f;
        --panel-bg: #ffffff;
        --panel-border: #ddd;
        --table-bg: #ffffff;
    }

        html[data-bs-theme="light"] .revisado-row td {
            background-color: #d4edda !important; /* verde clarito */
        }
        /* =========================
               BODY
            ========================= */
        html[data-bs-theme="light"] body {
            background: linear-gradient(180deg, var(--bg-top), var(--bg-bottom)) !important;
            color: var(--text-light) !important;
        }

        /* =========================
               KPI HEADER (🔥 clave)
            ========================= */
        html[data-bs-theme="light"] .sticky-kpis {
            background: #f4f6fb !important;
            background-image: none !important;
            border-bottom: 1px solid #ddd;
        }

        /* =========================
               KPI CARDS
            ========================= */
        html[data-bs-theme="light"] .kpi-card {
            background: #ffffff !important;
            color: #1e1e2f !important;
            border: 1px solid #ddd !important;
        }

        html[data-bs-theme="light"] .kpi-value {
            color: #000 !important;
        }

        html[data-bs-theme="light"] .kpi-sub {
            color: #555 !important;
        }

        /* =========================
               FILTROS
            ========================= */
        html[data-bs-theme="light"] .filter-card {
            background: #ffffff !important;
            border: 1px solid #ddd;
        }

        /* =========================
               INPUTS (🔥 con estados)
            ========================= */

        /* Normal */
        html[data-bs-theme="light"] .month-input {
            background: #ffffff !important;
            color: #000 !important;
            border: 1px solid #ccc !important;
        }

            /* Focus */
            html[data-bs-theme="light"] .month-input:focus {
                border-color: #0d6efd !important;
                box-shadow: 0 0 0 0.1rem rgba(13,110,253,.25);
            }

            /* Disabled */
            html[data-bs-theme="light"] .month-input:disabled {
                background: #e9ecef !important;
                color: #6c757d !important;
                border-color: #ced4da !important;
                cursor: not-allowed;
            }

            /* Readonly */
            html[data-bs-theme="light"] .month-input[readonly] {
                background: #f8f9fa !important;
                color: #495057 !important;
            }

        /* =========================
               TABLA
            ========================= */
        html[data-bs-theme="light"] .table {
            background: #ffffff !important;
            color: #000 !important;
        }

            html[data-bs-theme="light"] .table thead th {
                color: #333 !important;
                background: #f1f3f5 !important;
            }

            html[data-bs-theme="light"] .table tbody td {
                color: #000 !important;
            }

        /* =========================
               BOTONES
            ========================= */
        html[data-bs-theme="light"] .btn-ghost {
            color: #333 !important;
            border: 1px solid #ccc !important;
        }

            html[data-bs-theme="light"] .btn-ghost:hover {
                background: #e9ecef !important;
            }

            html[data-bs-theme="light"] .btn-ghost.active {
                background: #0d6efd !important;
                color: #fff !important;
            }

        /* =========================
               SELECT2 (IMPORTANTE)
            ========================= */
        html[data-bs-theme="light"] .select2-container--default .select2-selection--single {
            background-color: #ffffff !important;
            border: 1px solid #ccc !important;
            color: #000 !important;
        }

        html[data-bs-theme="light"] .select2-results__option {
            background: #fff !important;
            color: #000 !important;
        }

        html[data-bs-theme="light"] .select2-results__option--highlighted {
            background: #0d6efd !important;
            color: #fff !important;
        }

        /* =========================
               TEXTOS GENERALES
            ========================= */
        html[data-bs-theme="light"] label,
        html[data-bs-theme="light"] .form-label {
            color: #333 !important;
        }

        /* =========================
               CONTENEDORES
            ========================= */
        html[data-bs-theme="light"] .container-fluid {
            background: transparent !important;
        }

        /* =========================
               FOOTER
            ========================= */
        html[data-bs-theme="light"] footer.page-footer {
            background: #ffffff !important;
            color: #333 !important;
            border-top: 1px solid #ddd;
        }
        /* ===== SELECT2 TEXTO NEGRO (LIGHT MODE) ===== */
        html[data-bs-theme="light"] .select2-container--default .select2-selection--single {
            color: #000 !important;
        }

        /* Placeholder (cuando dice "Seleccione...") */
        html[data-bs-theme="light"] .select2-container--default .select2-selection__placeholder {
            color: #6c757d !important; /* gris bonito */
        }

        /* Texto seleccionado */
        html[data-bs-theme="light"] .select2-container--default .select2-selection__rendered {
            color: #000 !important;
        }

        /* Flechita */
        html[data-bs-theme="light"] .select2-container--default .select2-selection__arrow b {
            border-color: #000 transparent transparent transparent !important;
        }

        html[data-bs-theme="light"] .select2-dropdown {
            background: #fff !important;
            color: #000 !important;
        }

        html[data-bs-theme="light"] .select2-results__option {
            color: #000 !important;
        }

        /* Hover */
        html[data-bs-theme="light"] .select2-results__option--highlighted {
            background: #0d6efd !important;
            color: #fff !important;
        }
        /* ===== ICONOS GENERALES ===== */
        html[data-bs-theme="light"] i,
        html[data-bs-theme="light"] svg {
            color: #000 !important;
            fill: #000 !important;
        }
        /* Expand / botones / acciones */
        html[data-bs-theme="light"] .btn i,
        html[data-bs-theme="light"] .expand-icon i {
            color: #333 !important;
        }

        /* Hover bonito */
        html[data-bs-theme="light"] .btn:hover i,
        html[data-bs-theme="light"] .expand-icon:hover i {
            color: #0d6efd !important;
        }

        html[data-bs-theme="light"] .sidebar i {
            color: #333 !important;
        }

        html[data-bs-theme="light"] .sidebar a:hover i {
            color: #0d6efd !important;
        }

        html[data-bs-theme="light"] .sidebar a:hover i {
            color: #0d6efd !important;
        }
    /* =========================
       DARK MODE FIX (RESTAURAR)
    ========================= */
    html[data-bs-theme="dark"] {
        --bg-top: #0f172a; /* azul-negro */
        --bg-bottom: #1e293b;
        --text-light: #e9eef7;
        --panel-bg: rgba(255,255,255,0.04);
        --panel-border: rgba(255,255,255,0.06);
        --table-bg: rgba(6,12,28,0.65);
    }

        /* ===== KPI HEADER ===== */
        html[data-bs-theme="dark"] .sticky-kpis {
            background: linear-gradient(180deg, var(--bg-top), var(--bg-bottom)) !important;
        }

        /* ===== KPI CARDS ===== */
        html[data-bs-theme="dark"] .kpi-card {
            background: var(--panel-bg) !important;
            color: #e9eef7 !important;
            border: 1px solid var(--panel-border) !important;
        }

        /* ===== INPUTS ===== */
        html[data-bs-theme="dark"] .month-input {
            background: rgba(120, 160, 185, 0.35) !important;
            color: #e9eef7 !important;
            border-color: #7be6d4 !important;
        }

            /* Disabled */
            html[data-bs-theme="dark"] .month-input:disabled {
                background: rgba(120, 160, 185, 0.2) !important;
                color: rgba(255,255,255,0.6) !important;
            }

        /* ===== TABLA ===== */
        html[data-bs-theme="dark"] .table {
            background: transparent !important;
            color: #e9eef7 !important;
        }

            html[data-bs-theme="dark"] .table thead th {
                color: rgba(255,255,255,0.7) !important;
            }

        /* ===== SELECT2 ===== */
        html[data-bs-theme="dark"] .select2-container--default .select2-selection--single {
            background-color: rgba(6,12,28,0.65) !important;
            color: #fff !important;
            border: 1px solid #7be6d4 !important;
        }

        /* ===== ICONOS ===== */
        html[data-bs-theme="dark"] i,
        html[data-bs-theme="dark"] svg {
            color: #e9eef7 !important;
            fill: #e9eef7 !important;
        }

    html[data-bs-theme="light"] .detail-row td {
        background: #f3f3f3 !important;
    }

        html[data-bs-theme="light"] .detail-row td .month-input {
            background: #f3f3f3 !important;
            border: 1px solid #dcdcdc !important;
        }
</style>
<script>
    (function () {
        let theme = localStorage.getItem("theme");
        if (theme) {
            if (theme === "LightTheme")
                document.documentElement.setAttribute("data-bs-theme", "light");
            else if (theme === "DarkTheme")
                document.documentElement.setAttribute("data-bs-theme", "dark");
            else
                document.documentElement.setAttribute("data-bs-theme", "blue-theme");
        }
    })();
</script>
