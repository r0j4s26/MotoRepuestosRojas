                        <td class="text-center">
                            @(Model.Distritos.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton && a.CodDistrito == numDistrito) == null ? "Distrito Inexistente" : Model.Distritos.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton && a.CodDistrito == numDistrito).NomDistrito)
