@page "{id}"
@using System.Globalization
@model MotoRepuestosRojas.Pages.Clientes.ObservarModel
@{
    ViewData["Title"] = "Clientes";
    NumberFormatInfo formato = new CultureInfo("es-CR").NumberFormat;
    formato.CurrencySymbol = "";
    formato.CurrencyGroupSeparator = ",";
    formato.NumberDecimalSeparator = ".";


    var condicionPago = Model.Condiciones.FirstOrDefault(a => a.id == Model.Cliente.idCondicionPago);
    int numCanton = Convert.ToInt32(Model.Cliente.Canton);
    int numDistrito = Convert.ToInt32(Model.Cliente.Distrito);
    int numBarrio = Convert.ToInt32(Model.Cliente.Barrio);
}

@section styles {
    <link href="~/assets/plugins/datatable/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
}

@section scripts {
    <script src="~/assets/plugins/datatable/js/jquery.dataTables.min.js"></script>
    <script src="~/assets/plugins/datatable/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(function () {
            $('#cliente-direccion-datatable').DataTable({
                paging: false,
                searching: false,
                info: false,
                ordering: false
            });
        });

        function ImprimirPantalla() {
            try {
                const html = $(".html").html();
                html2pdf(html, {
                    margin: 1,
                    padding: 0,
                    filename: 'Cliente.pdf',
                    image: { type: 'jpeg', quality: 1 },
                    html2canvas: { scale: 2, logging: true },
                    jsPDF: { unit: 'in', format: 'A2', orientation: 'P' },
                    class: ImprimirPantalla
                });
            } catch (e) {
                console.log(e);
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Ha ocurrido un error al intentar imprimir ' + e
                });
            }
        }
    </script>
}

<main class="main-wrapper">
    <div class="main-content">
        <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
            <div class="breadcrumb-title pe-3">Clientes</div>
            <div class="ps-3">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 p-0">
                        <li class="breadcrumb-item">
                            <a href="#"><i class="bx bx-home-alt"></i></a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Observar Cliente</li>
                    </ol>
                </nav>
            </div>
            <div class="ms-auto d-flex gap-2">
                <a asp-page="./Index" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1">
                    <span class="material-icons-outlined fs-6">arrow_back</span>
                    Regresar
                </a>
                <button id="print" class="btn btn-warning btn-sm d-inline-flex align-items-center gap-1" type="button" onclick="ImprimirPantalla()">
                    <span class="material-icons-outlined fs-6">print</span>
                    Imprimir
                </button>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h6 class="mb-0 text-uppercase">Observar Cliente</h6>
                <span class="badge text-bg-primary">@Model.Cliente.id</span>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-4">
                    <div class="col-12 col-lg-4">
                        <div class="border rounded-3 p-3 h-100">
                            <p class="mb-1 text-secondary">Cliente</p>
                            <h5 class="mb-0 text-primary">@Model.Cliente.id - @Model.Cliente.Nombre</h5>
                        </div>
                    </div>
                    <div class="col-6 col-lg-2">
                        <div class="border rounded-3 p-3 h-100">
                            <p class="mb-1 text-secondary">@("Cédula")</p>
                            <h6 class="mb-0">@Model.Cliente.Cedula</h6>
                        </div>
                    </div>
               
                </div>

                <div class="row g-3 mb-4">
                 
                    <div class="col-md-6 col-xl-3">
                        <label class="form-label text-secondary mb-1">Teléfono</label>
                        <div class="fw-semibold">@Model.Cliente.Telefono</div>
                    </div>
                 
                    <div class="col-md-6 col-xl-3">
                        <label class="form-label text-secondary mb-1">Condición de Pago</label>
                        <div class="fw-semibold">@(condicionPago == null ? "Condición de Pago Inexistente" : condicionPago.Nombre)</div>
                    </div>
                    <div class="col-md-6 col-xl-3">
                        <label class="form-label text-secondary mb-1">Correo Factura</label>
                        <div class="fw-semibold">@Model.Cliente.Email</div>
                    </div>
      
                </div>

                <div class="table-responsive">
                    <table id="cliente-direccion-datatable" class="table table-striped table-bordered align-middle w-100">
                        <thead>
                            <tr>
                               
                                    <th class="text-center">Provincia</th>
                                    <th class="text-center">Cantón</th>
                                    <th class="text-center">Distrito</th>
                                    <th class="text-center">Barrio</th>
                                    <th class="text-center">Dirección</th>
                          
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-center">
                                   
                                        @switch (Model.Cliente.Provincia)
                                        {
                                            case 1:
                                                <span>San José</span>
                                                break;
                                            case 2:
                                                <span>Alajuela</span>
                                                break;
                                            case 3:
                                                <span>Cartago</span>
                                                break;
                                            case 4:
                                                <span>Heredia</span>
                                                break;
                                            case 5:
                                                <span>Guanacaste</span>
                                                break;
                                            case 6:
                                                <span>Puntarenas</span>
                                                break;
                                            case 7:
                                                <span>Limón</span>
                                                break;
                                        }
                                    
                                </td>
                                <td class="text-center">
                                    @(Model.Cantones.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton) == null ? "Canton Inexistente" : Model.Cantones.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton).NomCanton)
                                </td>
                                <td class="text-center">
                                    @(Model.Distritos.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton && a.CodDistrito == numDistrito) == null ? "Distrito Inexistente" : Model.Distritos.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton && a.CodDistrito == numDistrito).NomDistrito)
                                </td>
                              
                                    <td class="text-center">
                                        @(Model.Barrios.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton && a.CodDistrito == numDistrito && a.CodBarrio == numBarrio) == null ? "Barrio Inexistente" : Model.Barrios.FirstOrDefault(a => a.CodProvincia == Model.Cliente.Provincia && a.CodCanton == numCanton && a.CodDistrito == numDistrito && a.CodBarrio == numBarrio).NomBarrio)
                                    </td>
                                
                                <td class="text-center">@Model.Cliente.Sennas</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Imprimir -->
