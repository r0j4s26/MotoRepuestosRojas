@page
@model FORECAST.Pages.CondicionesPagos.NuevoModel
@{
    ViewData["Title"] = "Condiciones Pagos";
}

@section styles {
}

@section scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<div class="page-breadcrumb d-none d-sm-flex align-items-center mb-3">
    <div class="breadcrumb-title pe-3">Condiciones Pagos</div>
    <div class="ps-3">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 p-0">
                <li class="breadcrumb-item">
                    <a href="javascript:;"><i class="bx bx-home-alt"></i></a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Agregar Condición</li>
            </ol>
        </nav>
    </div>
    <div class="ms-auto">
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="card-title">
            <div class="row">
                <div class="col-sm-6">
                    <h4 class="mb-0">Agregar Condición</h4>
                </div>
                <div class="col-sm-6">
                    <a asp-page="./Index" class="btn btn-outline-light btn-sm float-end me-3" style="text-decoration: underline;">
                        Regresar
                    </a>
                </div>
            </div>
        </div>

        <hr />

        <form method="post" id="formTipos" role="form" novalidate class="needs-validation" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="nombre" class="form-label">Nombre de la Condición</label>
                        <div class="input-group">
                            <input type="text"
                                   id="nombre"
                                   asp-for="CondicionesPagos.Nombre"
                                   class="form-control border-start-0"
                                   required
                                   data-validation-required-message="Este campo es requerido">
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <label for="dias" class="form-label">Días</label>
                        <div class="input-group">
                            <input type="number"
                                   id="dias"
                                   asp-for="CondicionesPagos.Dias"
                                   class="form-control border-start-0"
                                   required
                                   data-validation-required-message="Este campo es requerido">
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <button type="submit" id="Guardar" class="btn btn-rounded btn-outline-success px-5">
                        Guardar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>